{
  "name": "vestora",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run dashboard\"",
    "server": "nodemon server/index.js",
    "dashboard": "cd dashboard && npx vite",
    "build": "npm install && cd dashboard && npm install && npm run build && cd .. && sh scripts/setup-db.sh",
    "start": "NODE_ENV=production PORT=3000 node server/index.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "seed": "node server/seed.js",
    "setup": "npm install && cd dashboard && npm install && cd .. && npx prisma generate && npx prisma db push && node server/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@mollie/api-client": "^4.5.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0"
  }
}
